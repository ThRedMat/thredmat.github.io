---
import { getCollection } from "astro:content";

// Layout import
import BaseLayout from "../layouts/BaseLayout.astro";

// Component Imports
import CallToAction from "../components/CallToAction.astro";
import Grid from "../components/Grid.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
import Pill from "../components/Pill.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";

// Page section components
import ContactCTA from "../components/ContactCTA.astro";
import Skills from "../components/Skills.astro";

// Content Fetching: List four most recent work projects
const projects = (await getCollection("work"))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 4);
---

<BaseLayout>
  <div class="stack gap-20 lg:gap-48">
    <div class="wrapper stack gap-8 lg:gap-20">
      <header class="hero">
        <div class="hero-content">
          <Hero
            title="Ingénieur Logiciel & Expert IA Agentique"
            tagline="Concevoir des architectures FullStack résilientes et orchestrer l'IA pour automatiser la valeur métier."
            align="start"
          >
            <div class="roles staggered-fade-in">
              <Pill><Icon icon="code" size="1.33em" /> FullStack Expert</Pill>
              <Pill><Icon icon="rocket-launch" size="1.33em" /> Certifié Anthropic Claude Actions</Pill>
              <Pill><Icon icon="strategy" size="1.33em" /> Culture de la Rigueur (SNCF)</Pill>
            </div>
            
            <div class="cv-download staggered-fade-in">
              <a href="https://drive.google.com/file/d/1sXSkfRyNRAcL1zTf7GFH-KCGLfL-z8q0/view?usp=sharing" target="_blank" class="cv-button">
                <Icon icon="paper-plane-tilt" size="1.2em" />
                Consulter mon profil (CV)
              </a>
            </div>
          </Hero>
        </div>

        <div class="hero-image-container fade-in">
          <img
            alt="Mathieu DARRIBAU - Développeur FullStack"
            width="480"
            height="620"
            src="/assets/photo-mathieu_darribau.jpeg"
          />
          <div class="image-accent"></div>
        </div>
      </header>

      <div class="fade-in delay-1">
        <Skills />
      </div>
    </div>

    <main class="wrapper stack gap-20 lg:gap-48">
      <section class="section with-background with-cta">
        <header class="section-header stack gap-2 lg:gap-4 fade-in">
          <h3>Projets Sélectionnés</h3>
          <p>
            Une sélection d'architectures web et de solutions IA pensées pour la performance et la sécurité.
          </p>
        </header>

        <div class="gallery">
          <Grid variant="offset">
            {
              projects.map((project, index) => (
                <li class="fade-in" style={`animation-delay: ${index * 0.15}s`}>
                  <PortfolioPreview project={project} />
                </li>
              ))
            }
          </Grid>
        </div>

        <div class="cta fade-in delay-2">
          <CallToAction href="/work/">
            Explorer l'intégralité du portfolio
            <Icon icon="arrow-right" size="1.2em" />
          </CallToAction>
        </div>
      </section>
    </main>

    <div class="fade-in">
      <ContactCTA />
    </div>
  </div>
</BaseLayout>

<style>
  /* ======================================================
     1. HERO & IMAGE
     ====================================================== */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .hero-image-container {
    position: relative;
    border-radius: 1.5rem;
  }

  .hero img {
    aspect-ratio: 5 / 4;
    object-fit: cover;
    object-position: top;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
    position: relative;
    z-index: 1;
  }

  .image-accent {
    position: absolute;
    inset: -10px;
    background: var(--gradient-accent);
    filter: blur(20px);
    opacity: 0.3;
    border-radius: 2rem;
    z-index: 0;
  }

  /* ======================================================
     2. BOUTON CV (Plus sobre, plus pro)
     ====================================================== */
  .cv-download {
    margin-top: 1.5rem;
  }

  .cv-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.8rem 2rem;
    background: var(--gray-999);
    color: var(--gray-0);
    border: 1px solid var(--accent-regular);
    text-decoration: none;
    border-radius: 999rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    box-shadow: var(--shadow-sm);
  }

  .cv-button:hover {
    background: var(--gradient-accent);
    color: white;
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    border-color: transparent;
  }

  /* ======================================================
     3. ANIMATIONS AVANCÉES
     ====================================================== */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s cubic-bezier(0.2, 0.8, 0.2, 1), 
                transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-1 { transition-delay: 0.2s; }
  .delay-2 { transition-delay: 0.4s; }

  /* Animation séquentielle pour les badges et boutons */
  .staggered-fade-in {
    opacity: 0;
    transform: translateX(-10px);
    animation: slideIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .staggered-fade-in:nth-child(1) { animation-delay: 0.3s; }
  .staggered-fade-in:nth-child(2) { animation-delay: 0.5s; }

  @keyframes slideIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ======================================================
     4. RESPONSIVE & LAYOUT
     ====================================================== */
  .roles {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  @media (min-width: 50em) {
    .hero {
      display: grid;
      grid-template-columns: 6fr 4fr;
      padding-inline: 2.5rem;
      gap: 3.75rem;
    }

    .hero img {
      aspect-ratio: 3 / 4;
      border-radius: 4.5rem;
    }
  }

  .section { display: grid; gap: 2rem; }
  .with-background { position: relative; }
  .section-header { justify-self: center; text-align: center; max-width: 50ch; color: var(--gray-300); }
  .section-header h3 { font-size: var(--text-2xl); color: var(--gray-0); }

  @media (min-width: 50em) {
    .section {
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas: "header header header cta" "gallery gallery gallery gallery";
      gap: 5rem;
    }
    .section-header { grid-area: header; justify-self: flex-start; text-align: left; }
    .section-header h3 { font-size: var(--text-4xl); }
    .gallery { grid-area: gallery; }
    .cta { grid-area: cta; align-self: flex-end; }
  }
</style>

<script>
  // Animation au scroll avec Intersection Observer
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.fade-in').forEach((element) => {
    observer.observe(element);
  });
</script>